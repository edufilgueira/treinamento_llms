# Copiar: cp server_for_serveless/.env.example server_for_serveless/.env
# Carga: primeiro .env na raiz do repo, depois server_for_serveless/.env (este sobrepõe).
# Obrigatório: ORACULO_PG_HOST (e credenciais PostgreSQL que uses).

# --- PostgreSQL ---
ORACULO_PG_HOST=127.0.0.1
ORACULO_PG_PORT=5432
ORACULO_PG_USER=postgres
ORACULO_PG_PASSWORD=
ORACULO_PG_DATABASE=oraculo
ORACULO_PG_SSLMODE=prefer
ORACULO_PG_CONNECT_TIMEOUT=15
ORACULO_PG_MAINTENANCE_DB=postgres
ORACULO_PG_AUTO_CREATE_DATABASE=1

# --- Opcional: servidor HTTP ---
# ORACULO_BIND_HOST=0.0.0.0

# Para debug no terminal (stderr): data no system, ordenação da lista, truncagem já aplicados.
# Ver também ORACULO_CONTEXT_TIMEZONE. Desligado por defeito.
ORACULO_DEBUG_UPSTREAM_MESSAGES=false

# --- Opcional: data no texto de contexto enviado ao modelo (timezone IANA). Por defeito: America/Sao_Paulo.
# Outros exemplos: Europe/Lisbon, America/Fortaleza.
# ORACULO_CONTEXT_TIMEZONE=America/Sao_Paulo

# --- Opcional: sessão / primeiro admin ---
# ORACULO_SESSION_SECRET=
# ORACULO_NO_BOOTSTRAP_ADMIN_PASSWORD=1

# --- Inferência: Runpod Serverless ---
# Se definires as duas variáveis abaixo, o arranque usa Runpod (api.runpod.ai) em vez de llama-server HTTP.
# A chave NÃO vai no código (ex. runpod_upstream.py): cola-a só neste ficheiro ou no .env da raiz.
#
#   ORACULO_RUNPOD_ENDPOINT_ID — ID do endpoint no painel Runpod (Serverless → Endpoints).
#   ORACULO_RUNPOD_API_KEY      — API Key com prefixo rpa_... (Settings / API Keys no Runpod).
#
# Têm de existir AMBAS; senão o servidor falha no startup. Ver README_RUNPOD_SERVERLESS.md.
#
# ORACULO_RUNPOD_ENDPOINT_ID=seu_id_do_endpoint
# ORACULO_RUNPOD_API_KEY=rpa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ORACULO_RUNPOD_MODEL_ID=runpod
# ORACULO_RUNPOD_POLL_TIMEOUT_S=900
# ORACULO_RUNPOD_POLL_INTERVAL_S=1
# ORACULO_RUNPOD_STARTUP_HEALTH=0

# --- Inferência (excepto --ui-only): llama-server HTTP ---
# Usado quando NÃO definires ORACULO_RUNPOD_ENDPOINT_ID + ORACULO_RUNPOD_API_KEY acima.
# Se omitires a URL, usa-se http://127.0.0.1:8080. O admin (PostgreSQL) pode sobrepor com host/porta.
# ORACULO_LLAMA_CPP_BASE_URL=http://127.0.0.1:8080
# ORACULO_LLAMA_CPP_REQUIRE_EXPLICIT_URL=1
# ORACULO_LLAMA_CPP_API_KEY=
# ORACULO_LLAMA_CPP_MODEL=
# JSON de kwargs do Jinja para o llama-server (Qwen3: enable_thinking).
# Só o processo Python lê server_for_serveless/.env ou .env na raiz — ficheiros .ini do systemd
# exigem Environment=... ou EnvironmentFile= com as mesmas variáveis.
# ORACULO_LLAMA_CPP_CHAT_TEMPLATE_KWARGS={"enable_thinking":false}

# --- Comportamento global (fila, bloqueio na UI, modo só interface) — configurar em Configurações do modelo (admin). ---
# ORACULO_UI_ONLY=1 ou ./serve.sh -- --ui-only  força só interface no arranque (operações / diagnóstico),
# mesmo que na base de dados o modo esteja desligado.

# --- Opcional: proteger POST /v1/* ---
# ORACULO_OPENAI_API_KEY=
