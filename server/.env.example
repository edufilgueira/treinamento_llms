# Copia este ficheiro para server/.env e preenche (PostgreSQL, etc.).
# O array do servidor carrega .env da raiz do repositório e depois server/.env
# (este último substitui chaves iguais).

# PostgreSQL
ORACULO_PG_HOST=127.0.0.1
ORACULO_PG_PORT=5432
ORACULO_PG_USER=postgres
ORACULO_PG_PASSWORD=
ORACULO_PG_DATABASE=oraculo
ORACULO_PG_SSLMODE=prefer
# ORACULO_PG_MAINTENANCE_DB=postgres
# ORACULO_PG_AUTO_CREATE_DATABASE=1

# Opcional: não redefinir a password do admin em cada arranque
# ORACULO_NO_BOOTSTRAP_ADMIN_PASSWORD=1

# Só modelo base do Hub (sem pasta lora_adapter, sem merge). Requer o stack HF (não gguf).
# ORACULO_BASE_ONLY=1
# ORACULO_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3
# Não use IDs *-GGUF* (só ficheiros .gguf) aqui: para .gguf use ORACULO_INFERENCE_BACKEND=gguf + ORACULO_GGUF_PATH.

# Opcional: adapter LoRA (por defeito <raiz do repo>/trein/outputs/lora_adapter)
# ORACULO_ADAPTER_DIR=/var/www/treinamento_llms/trein/outputs/lora_adapter
#
# Modelo fundido (merge_lora.py) — se existir, o servidor carrega isto em vez de base+LoRA
# (por defeito: trein/outputs/merged_model quando tem pesos; sobrepõe o caminho do CLI)
# ORACULO_MERGED_MODEL_DIR=/workspace/treinamento_llms/trein/outputs/merged_model
#
# --- Performance (PyTorch) — lora_engine ao carregar o modelo; GPU aconselhado ---
# Atenção SDPA (rápido, sem dependências). Se o modelo der erro, tente: eager
# ORACULO_ATTN_IMPLEMENTATION=sdpa
# Precisão de matmul float32 (high/highest/medium) — ligeiro ganho em RTX
# ORACULO_MATMUL_PRECISION=high
# 1 = cudnn.benchmark (útil com formas de entrada mais fixas; experimentar)
# ORACULO_CUDNN_BENCHMARK=0
# 1 = torch.compile (1.ª geração mais lenta; testar consoante o GPU)
# ORACULO_TORCH_COMPILE=0
# ORACULO_TORCH_COMPILE_MODE=reduce-overhead
# 0 = não fazer forward de aquecimento após o load
# ORACULO_TORCH_WARMUP=1

# --- Motor de inferência: HF (PyTorch) vs GGUF (llama-cpp-python) — ver README_INFERENCE_HF_GGUF.md ---
# ORACULO_INFERENCE_BACKEND=hf
# ORACULO_INFERENCE_BACKEND=gguf
# ORACULO_GGUF_PATH=/caminho/para/meu-Merged-Q4_K_M.gguf
# ORACULO_GGUF_N_CTX=4096
# ORACULO_GGUF_N_GPU_LAYERS=-1

# API OpenAI-compat (/v1/chat/completions): se definido, exige Authorization: Bearer <esta chave>
# ORACULO_OPENAI_API_KEY=coloque_uma_chave_secreta
