# Copiar: cp server/.env.example server/.env
# Carga: primeiro .env na raiz do repo, depois server/.env (este sobrepõe).
# Obrigatório: ORACULO_PG_HOST (e credenciais PostgreSQL que uses).

# --- PostgreSQL ---
ORACULO_PG_HOST=127.0.0.1
ORACULO_PG_PORT=5432
ORACULO_PG_USER=postgres
ORACULO_PG_PASSWORD=
ORACULO_PG_DATABASE=oraculo
ORACULO_PG_SSLMODE=prefer
ORACULO_PG_CONNECT_TIMEOUT=15
ORACULO_PG_MAINTENANCE_DB=postgres
ORACULO_PG_AUTO_CREATE_DATABASE=1

# --- Opcional: servidor HTTP ---
# ORACULO_BIND_HOST=0.0.0.0

# --- Opcional: sessão / primeiro admin ---
# ORACULO_SESSION_SECRET=
# ORACULO_NO_BOOTSTRAP_ADMIN_PASSWORD=1

# --- Inferência (obrigatório excepto --ui-only): llama-server ---
# O URL no admin (PostgreSQL) pode substituir ou complementar isto.
ORACULO_LLAMA_CPP_BASE_URL=http://127.0.0.1:8080
# ORACULO_LLAMA_CPP_API_KEY=
# ORACULO_LLAMA_CPP_MODEL=
# ORACULO_LLAMA_CPP_CHAT_TEMPLATE_KWARGS={"enable_thinking":false}

# --- Opcional: proteger POST /v1/* ---
# ORACULO_OPENAI_API_KEY=

# --- Opcional: só UI + auth, sem chamar llama-server ---
# ORACULO_UI_ONLY=1
