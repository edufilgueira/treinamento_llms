# =============================================================================
# Oráculo (treinamento_llms) — copiar para server/.env e descomentar o que precisares.
#   cp server/.env.example server/.env
# O serve_lora.py exige server/.env ou .env na raiz; ORACULO_PG_HOST obrigatório.
# Ordem de carga: .env na raiz, depois server/.env (sobrepõe chaves iguais).
# =============================================================================

# ---------- Linhas ACTIVAS: desligar raciocínio explícito (Qwen3 / GGUF) ----------
# Mantém ENABLE e DISABLE_JINJA a 0 — assim o servidor usa Jinja com enable_thinking=false.
ORACULO_GGUF_ENABLE_THINKING=0
ORACULO_GGUF_DISABLE_JINJA_NO_THINK=0
ORACULO_GGUF_REASONING_BUDGET=0
ORACULO_GGUF_STREAM_STRIP_THINKING=0

# --- PostgreSQL (obrigatório para arrancar — descomenta e preenche) ---
ORACULO_PG_HOST=127.0.0.1
ORACULO_PG_PORT=5432
ORACULO_PG_USER=postgres
ORACULO_PG_PASSWORD=
ORACULO_PG_DATABASE=oraculo
ORACULO_PG_SSLMODE=prefer
ORACULO_PG_MAINTENANCE_DB=postgres
ORACULO_PG_AUTO_CREATE_DATABASE=1
ORACULO_PG_CONNECT_TIMEOUT=15

# --- HTTP (uvicorn) ---
# ORACULO_BIND_HOST=0.0.0.0
# ORACULO_BIND_HOST=127.0.0.1

# --- Sessão / admin ---
# ORACULO_SESSION_SECRET=
# ORACULO_NO_BOOTSTRAP_ADMIN_PASSWORD=1

# --- Modelo (HF + LoRA / merge) — ver trein/data_config.py ---
# ORACULO_MODEL_NAME=Qwen/Qwen2.5-3B-Instruct
# ORACULO_BASE_ONLY=1
# ORACULO_ADAPTER_DIR=trein/outputs/lora_adapter
# ORACULO_MERGED_MODEL_DIR=trein/outputs/merged_model

# --- Motor GGUF — README_INFERENCE_HF_GGUF.md ---
# ORACULO_INFERENCE_BACKEND=hf
# ORACULO_INFERENCE_BACKEND=gguf
# ORACULO_GGUF_PATH=tools/quantized_model/Merged_Model-3.1B-Q4_K_M.gguf
# ORACULO_GGUF_N_CTX=4096
# ORACULO_GGUF_N_GPU_LAYERS=-1

# (Thinking GGUF: as linhas activas no topo já forçam o modo sem pensamento;
#  só altera se souberes o efeito: ENABLE_THINKING=1 mostra raciocínio;
#  DISABLE_JINJA_NO_THINK=1 desactiva o formatter Jinja — não uses salvo depuração.)

# --- Performance (PyTorch / HF) ---
# ORACULO_ATTN_IMPLEMENTATION=sdpa
# ORACULO_MATMUL_PRECISION=high
# ORACULO_CUDNN_BENCHMARK=0
# ORACULO_TORCH_COMPILE=0
# ORACULO_TORCH_COMPILE_MODE=reduce-overhead
# ORACULO_TORCH_WARMUP=1

# --- API OpenAI-compat (/v1/*) ---
# ORACULO_OPENAI_API_KEY=

# --- Outros ---
# ORACULO_UI_ONLY=1
